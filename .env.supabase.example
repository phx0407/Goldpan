# Supabase Phase 1 — required environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase project URL (from Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service role key (from Settings → API → service_role)
# WARNING: This key bypasses RLS. Only use in server-side scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Path to Google service account JSON file (for Sheets read access)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Optional: Anthropic API key (already in .env — do not duplicate if present)
# ANTHROPIC_API_KEY=sk-ant-...
