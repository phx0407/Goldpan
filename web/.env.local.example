# Copy to .env.local and fill in values.
# These are server-side only — never prefix with NEXT_PUBLIC_.

# FastAPI backend URL (local dev default)
GOLDPAN_API_URL=http://localhost:8000

# Must match ADMIN_API_KEY in goldpan/.env
ADMIN_API_KEY=your-admin-key-here

# operations.users.user_id (UUID) to attribute Intake OS write actions
# (claim/release/approve/return/reject/edit_payload/resubmit/archive) to.
# TEMPORARY bridge — see api/deps.py get_acting_user docstring. This admin
# tool has no per-user auth session yet, so a single configured user acts
# as the reviewer/specialist/admin for every mutation, mirroring how
# ADMIN_API_KEY is a single shared secret. Must reference an existing,
# active operations.users row or every claim/release/approve/... call will
# fail with 503. Not required for /ingest.
GOLDPAN_ACTING_USER_ID=
